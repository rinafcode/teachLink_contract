use soroban_sdk::{contract, contractimpl, symbol_short, Address, Bytes, Env, Map, Vec, Symbol};

/// Chain configuration for different blockchains
#[derive(Clone, Debug)]
pub struct ChainConfig {
    pub chain_id: u32,
    pub name: Symbol,
    pub bridge_address: Address,
    pub min_confirmations: u32,
    pub fee_rate: u32,
}

/// Oracle price data
#[derive(Clone, Debug)]
pub struct OraclePrice {
    pub asset: Symbol,
    pub price: i128,
    pub timestamp: u64,
    pub confidence: u32, // 0-100 scale
}

/// External call validation result
#[derive(Clone, Debug)]
pub struct ExternalCallResult {
    pub success: bool,
    pub return_data: Bytes,
    pub error_code: Option<u32>,
}

/// Rate limiting configuration
#[derive(Clone, Debug)]
pub struct RateLimitConfig {
    pub max_calls_per_minute: u32,
    pub max_calls_per_hour: u32,
    pub penalty_multiplier: u32,
}

/// TeachLink main contract with multi-chain and oracle support.
#[contract]
pub struct TeachLinkBridge;

#[contractimpl]
impl TeachLinkBridge {
    // Storage keys
    const CHAIN_CONFIGS: Symbol = symbol_short!("chains");
    const ORACLE_PRICES: Symbol = symbol_short!("prices");
    const RATE_LIMITS: Symbol = symbol_short!("rate_limits");
    const EXTERNAL_CALL_RESULTS: Symbol = symbol_short!("ext_calls");
    const FALLBACK_ENABLED: Symbol = symbol_short!("fallback");
    
    // Constants
    const DEFAULT_MIN_CONFIRMATIONS: u32 = 3;
    const DEFAULT_FEE_RATE: u32 = 100; // basis points (1%)
    const DEFAULT_RATE_LIMIT_PER_MINUTE: u32 = 10;
    const DEFAULT_RATE_LIMIT_PER_HOUR: u32 = 100;
    const DEFAULT_PENALTY_MULTIPLIER: u32 = 2;
    const MAX_CONFIDENCE_THRESHOLD: u32 = 80; // Minimum confidence for oracle data
    const FALLBACK_PRICE: i128 = 1000000; // 1 USD in 6 decimals
    
    /// Initialize the bridge contract with multi-chain support
    pub fn initialize(
        env: Env,
        admin: Address,
    ) {
        // Initialize storage
        env.storage().instance().set(&symbol_short!("admin"), &admin);
        env.storage().instance().set(&symbol_short!("nonce"), &0u64);
        env.storage().instance().set(&FALLBACK_ENABLED, &true);
        
        // Initialize default rate limits
        let default_rate_limits = RateLimitConfig {
            max_calls_per_minute: DEFAULT_RATE_LIMIT_PER_MINUTE,
            max_calls_per_hour: DEFAULT_RATE_LIMIT_PER_HOUR,
            penalty_multiplier: DEFAULT_PENALTY_MULTIPLIER,
        };
        env.storage().instance().set(&RATE_LIMITS, &default_rate_limits);
        
        // Initialize empty chain configurations
        env.storage().instance().set(&CHAIN_CONFIGS, &Vec::new(&env));
        env.storage().instance().set(&ORACLE_PRICES, &Vec::new(&env));
        env.storage().instance().set(&EXTERNAL_CALL_RESULTS, &Vec::new(&env));
    }
    
    /// Add support for a new chain
    pub fn add_chain_support(
        env: Env,
        chain_id: u32,
        name: Symbol,
        bridge_address: Address,
        min_confirmations: u32,
        fee_rate: u32,
    ) -> Result<(), Symbol> {
        // Check admin authorization
        let admin: Address = env.storage()
            .instance()
            .get(&symbol_short!("admin"))
            .unwrap_or_else(|| {
                env.panic_with_error_data(
                    &symbol_short!("not_init"),
                    "Contract not initialized",
                )
            });
        
        if env.current_contract_address() != admin {
            return Err(symbol_short!("unauthorized"));
        }
        
        // Validate inputs
        if chain_id == 0 {
            return Err(symbol_short!("invalid_chain"));
        }
        
        if fee_rate > 10000 { // Max 100%
            return Err(symbol_short!("fee_too_high"));
        }
        
        // Create chain configuration
        let chain_config = ChainConfig {
            chain_id,
            name,
            bridge_address,
            min_confirmations,
            fee_rate,
        };
        
        // Add to chain configurations
        let mut chains: Vec<ChainConfig> = env.storage()
            .instance()
            .get(&CHAIN_CONFIGS)
            .unwrap_or(Vec::new(&env));
        
        for existing_chain in chains.iter() {
            if existing_chain.chain_id == chain_id {
                return Err(symbol_short!("chain_exists"));
            }
        }
        
        chains.push_back(chain_config);
        env.storage().instance().set(&Self::CHAIN_CONFIGS, &chains);
        
        Ok(symbol_short!("success"))
    }
    
    /// Update oracle price data with validation
    pub fn update_oracle_price(
        env: Env,
        asset: Symbol,
        price: i128,
        confidence: u32,
        oracle_signer: Address,
    ) -> Result<(), Symbol> {
        // Validate price data
        if price <= 0 {
            return Err(symbol_short!("invalid_price"));
        }
        
        if confidence > 100 {
            return Err(symbol_short!("invalid_confidence"));
        }
        
        // Check if oracle is authorized (simplified - in production, use whitelist)
        let authorized_oracles: Vec<Address> = env.storage()
            .instance()
            .get(&symbol_short!("oracles"))
            .unwrap_or(Vec::new(&env));
        
        let mut is_authorized = false;
        for oracle in authorized_oracles.iter() {
            if oracle == oracle_signer {
                is_authorized = true;
                break;
            }
        }
        
        if !is_authorized {
            return Err(symbol_short!("unauthorized_oracle"));
        }
        
        // Create oracle price entry
        let oracle_price = OraclePrice {
            asset,
            price,
            timestamp: env.ledger().timestamp(),
            confidence,
        };
        
        // Update oracle prices
        let mut prices: Vec<OraclePrice> = env.storage()
            .instance()
            .get(&Self::ORACLE_PRICES)
            .unwrap_or(Vec::new(&env));
        
        // Update existing price or add new one
        let mut updated = false;
        for i in 0..prices.len() {
            if prices.get(i).unwrap().asset == asset {
                prices.set(i, oracle_price.clone());
                updated = true;
                break;
            }
        }
        
        if !updated {
            prices.push_back(oracle_price);
        }
        
        env.storage().instance().set(&ORACLE_PRICES, &prices);
        
        Ok(symbol_short!("success"))
    }
    
    /// Bridge tokens with multi-chain support and external validation
    pub fn bridge_out(
        env: Env,
        from: Address,
        amount: i128,
        destination_chain: u32,
        destination_address: Bytes,
        use_oracle: bool, // Whether to use oracle for price conversion
    ) -> Result<u64, Symbol> {
        // Check rate limits
        let rate_limit_config: RateLimitConfig = env.storage()
            .instance()
            .get(&RATE_LIMITS)
            .unwrap_or_else(|| {
                RateLimitConfig {
                    max_calls_per_minute: DEFAULT_RATE_LIMIT_PER_MINUTE,
                    max_calls_per_hour: DEFAULT_RATE_LIMIT_PER_HOUR,
                    penalty_multiplier: DEFAULT_PENALTY_MULTIPLIER,
                }
            });
        
        if !self.check_rate_limit(env, from, &rate_limit_config) {
            return Err(symbol_short!("rate_limited"));
        }
        
        // Get chain configuration
        let chains: Vec<ChainConfig> = env.storage()
            .instance()
            .get(&CHAIN_CONFIGS)
            .unwrap_or(Vec::new(&env));
        
        let mut chain_config: Option<ChainConfig> = None;
        for chain in chains.iter() {
            if chain.chain_id == destination_chain {
                chain_config = Some(chain.clone());
                break;
            }
        }
        
        let chain_config = chain_config.ok_or_else(|| {
            env.panic_with_error_data(
                &symbol_short!("unsupported_chain"),
                "Destination chain not supported",
            )
        })?;
        
        // Calculate fees
        let fee_amount = amount * chain_config.fee_rate as i128 / 10000;
        let bridge_amount = amount - fee_amount;
        
        // Get oracle price if requested
        let price_multiplier = if use_oracle {
            self.get_oracle_price(env, &symbol_short!("USD"))?
                .price as i128
                / FALLBACK_PRICE
        } else {
            FALLBACK_PRICE
        };
        
        // Store bridge transaction
        let nonce = self.get_next_nonce(env);
        let bridge_data = (from, bridge_amount, destination_chain, destination_address);
        
        let mut bridge_txs: Vec<(Address, i128, u32, Bytes)> = env.storage()
            .instance()
            .get(&symbol_short!("bridge_txs"))
            .unwrap_or(Vec::new(&env));
        bridge_txs.push_back(bridge_data);
        env.storage().instance().set(&symbol_short!("bridge_txs"), &bridge_txs);
        
        // Attempt external call to destination chain
        let external_result = self.attempt_external_bridge(
            env,
            &chain_config.bridge_address,
            bridge_amount,
            destination_address,
            price_multiplier,
        );
        
        // Store external call result
        let mut results: Vec<ExternalCallResult> = env.storage()
            .instance()
            .get(&Self::EXTERNAL_CALL_RESULTS)
            .unwrap_or(Vec::new(&env));
        results.push_back(external_result);
        env.storage().instance().set(&EXTERNAL_CALL_RESULTS, &results);
        
        if external_result.success {
            Ok(nonce)
        } else {
            Err(symbol_short!("bridge_failed"))
        }
    }
    
    /// Attempt external bridge call with validation and fallback
    fn attempt_external_bridge(
        env: Env,
        bridge_address: &Address,
        amount: i128,
        destination_address: &Bytes,
        price_multiplier: i128,
    ) -> ExternalCallResult {
        // In a real implementation, this would make an external contract call
        // For now, we simulate the call with validation
        
        // Validate destination address
        if destination_address.len() == 0 {
            return ExternalCallResult {
                success: false,
                return_data: Bytes::new(&env),
                error_code: Some(1001), // Invalid address
            };
        }
        
        // Validate amount
        if amount <= 0 {
            return ExternalCallResult {
                success: false,
                return_data: Bytes::new(&env),
                error_code: Some(1002), // Invalid amount
            };
        }
        
        // Check if fallback is enabled for failed external calls
        let fallback_enabled = env.storage()
            .instance()
            .get(&FALLBACK_ENABLED)
            .unwrap_or(true);
        
        // Simulate successful bridge (in production, this would be an external call)
        ExternalCallResult {
            success: true,
            return_data: Bytes::new(&env), // Would contain transaction hash
            error_code: None,
        }
    }
    
    /// Get oracle price with fallback
    fn get_oracle_price(env: Env, asset: &Symbol) -> Result<OraclePrice, Symbol> {
        let prices: Vec<OraclePrice> = env.storage()
            .instance()
            .get(&ORACLE_PRICES)
            .unwrap_or(Vec::new(&env));
        
        for price in prices.iter() {
            if price.asset == *asset {
                // Check if price is fresh (within 1 hour)
                let current_time = env.ledger().timestamp();
                if current_time - price.timestamp < 3600 { // 1 hour in seconds
                    // Check confidence threshold
                    if price.confidence >= MAX_CONFIDENCE_THRESHOLD {
                        return Ok(price.clone());
                    }
                }
            }
        }
        
        // Return fallback price if no fresh oracle data available
        Ok(OraclePrice {
            asset: *asset,
            price: Self::FALLBACK_PRICE,
            timestamp: env.ledger().timestamp(),
            confidence: 100, // Maximum confidence for fallback
        })
    }
    
    /// Check rate limits for user
    fn check_rate_limit(
        env: Env,
        user: Address,
        config: &RateLimitConfig,
    ) -> bool {
        let current_time = env.ledger().timestamp();
        let user_key = symbol_short!("rate_limit_");
        let user_key_full = symbol_short!(&format!("{}_{}", user_key, user));
        
        // Get user rate limit data
        let rate_data: (u64, u64) = env.storage()
            .instance()
            .get(&user_key_full)
            .unwrap_or((0, 0)); // (last_minute_timestamp, call_count_in_minute, last_hour_timestamp, call_count_in_hour)
        
        let (last_minute, count_in_minute, last_hour, count_in_hour) = rate_data;
        
        // Check minute limit
        if current_time - last_minute < 60 && count_in_minute >= config.max_calls_per_minute as u64 {
            // Apply penalty
            return false;
        }
        
        // Check hour limit
        if current_time - last_hour < 3600 && count_in_hour >= config.max_calls_per_hour as u64 {
            // Apply penalty
            return false;
        }
        
        // Update rate limit counters
        let new_minute = if current_time - last_minute >= 60 { current_time } else { last_minute };
        let new_hour = if current_time - last_hour >= 3600 { current_time } else { last_hour };
        
        let new_count_in_minute = if current_time - last_minute >= 60 { 1 } else { count_in_minute + 1 };
        let new_count_in_hour = if current_time - last_hour >= 3600 { 1 } else { count_in_hour + 1 };
        
        env.storage().instance().set(&user_key_full, &(new_minute, new_count_in_minute, new_hour, new_count_in_hour));
        
        true
    }
    
    /// Get next nonce
    fn get_next_nonce(env: Env) -> u64 {
        let nonce = env.storage()
            .instance()
            .get(&symbol_short!("nonce"))
            .unwrap_or(0u64);
        let new_nonce = nonce + 1;
        env.storage()
            .instance()
            .set(&symbol_short!("nonce"), &new_nonce);
        new_nonce
    }
    
    /// Get chain configuration
    pub fn get_chain_config(env: Env, chain_id: u32) -> Option<ChainConfig> {
        let chains: Vec<ChainConfig> = env.storage()
            .instance()
            .get(&CHAIN_CONFIGS)
            .unwrap_or(Vec::new(&env));
        
        for chain in chains.iter() {
            if chain.chain_id == chain_id {
                return Some(chain.clone());
            }
        }
        
        None
    }
    
    /// Get oracle price
    pub fn get_oracle_price(env: Env, asset: Symbol) -> Option<OraclePrice> {
        let prices: Vec<OraclePrice> = env.storage()
            .instance()
            .get(&ORACLE_PRICES)
            .unwrap_or(Vec::new(&env));
        
        for price in prices.iter() {
            if price.asset == asset {
                return Some(price.clone());
            }
        }
        
        None
    }
    
    /// Get external call result
    pub fn get_external_call_result(env: Env, index: u32) -> Option<ExternalCallResult> {
        let results: Vec<ExternalCallResult> = env.storage()
            .instance()
            .get(&EXTERNAL_CALL_RESULTS)
            .unwrap_or(Vec::new(&env));
        
        results.get(index)
    }
    
    /// Enable/disable fallback mechanism
    pub fn set_fallback_enabled(env: Env, enabled: bool) {
        env.storage().instance().set(&Self::FALLBACK_ENABLED, &enabled);
    }
    
    /// Get fallback status
    pub fn is_fallback_enabled(env: Env) -> bool {
        env.storage()
            .instance()
            .get(&FALLBACK_ENABLED)
            .unwrap_or(true)
    }
}

#[cfg(test)]
mod tests {
    use super::*;
    
    #[test]
    fn test_add_chain_support() {
        let env = Env::default();
        let admin = Address::generate_random(&env);
        
        // Initialize contract
        super::TeachLinkBridge::initialize(env.clone(), admin.clone());
        
        let chain_id = 1u32;
        let name = Symbol::new(&env, "Ethereum");
        let bridge_address = Address::generate_random(&env);
        let min_confirmations = 12u32;
        let fee_rate = 50u32;
        
        // Add chain support
        let result = super::TeachLinkBridge::add_chain_support(
            env.clone(),
            chain_id,
            name,
            bridge_address,
            min_confirmations,
            fee_rate,
        );
        
        assert!(result.is_ok());
    }
    
    #[test]
    fn test_oracle_price_update() {
        let env = Env::default();
        let admin = Address::generate_random(&env);
        
        // Initialize contract
        super::TeachLinkBridge::initialize(env.clone(), admin.clone());
        
        let asset = Symbol::new(&env, "USD");
        let price = 2000i128;
        let confidence = 95u32;
        let oracle = Address::generate_random(&env);
        
        // Update oracle price
        let result = super::TeachLinkBridge::update_oracle_price(
            env.clone(),
            asset,
            price,
            confidence,
            oracle,
        );
        
        assert!(result.is_ok());
        
        // Verify price was stored
        let stored_price = super::TeachLinkBridge::get_oracle_price(env.clone(), asset);
        assert!(stored_price.is_some());
        assert_eq!(stored_price.unwrap().price, price);
    }
    
    #[test]
    fn test_rate_limiting() {
        let env = Env::default();
        let admin = Address::generate_random(&env);
        let user = Address::generate_random(&env);
        
        // Initialize contract
        super::TeachLinkBridge::initialize(env.clone(), admin.clone());
        
        // Set custom rate limits for testing
        let rate_limits = RateLimitConfig {
            max_calls_per_minute: 2,
            max_calls_per_hour: 5,
            penalty_multiplier: 1,
        };
        env.storage().instance().set(&symbol_short!("rate_limits"), &rate_limits);
        
        // First call should succeed
        let result1 = super::TeachLinkBridge::check_rate_limit(env.clone(), user.clone(), &rate_limits);
        assert!(result1);
        
        // Second call should succeed
        let result2 = super::TeachLinkBridge::check_rate_limit(env.clone(), user.clone(), &rate_limits);
        assert!(result2);
        
        // Third call should fail (exceeds minute limit)
        let result3 = super::TeachLinkBridge::check_rate_limit(env.clone(), user.clone(), &rate_limits);
        assert!(!result3);
    }
}
